<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>TaskFlow — To-Do App</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  /* ─── TOKENS ─────────────────────────────────────────────── */
  :root {
    --bg:        #0f1117;
    --surface:   #181b25;
    --elevated:  #1e2235;
    --border:    #2a2f45;
    --accent:    #6366f1;        /* indigo */
    --accent-lo: #6366f118;
    --accent-hi: #818cf8;
    --danger:    #f43f5e;
    --success:   #10b981;
    --muted:     #4b5270;
    --sub:       #6b7280;
    --text:      #e2e4ed;
    --text-dim:  #9ca3af;
    --radius:    10px;
    --radius-sm: 6px;
    --shadow:    0 4px 24px #00000055;
    --trans:     .18s cubic-bezier(.4,0,.2,1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 16px 80px;
  }

  /* ─── HEADER ─────────────────────────────────────────────── */
  header {
    width: 100%;
    max-width: 580px;
    margin-bottom: 32px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }

  .brand-icon {
    width: 36px; height: 36px;
    background: var(--accent);
    border-radius: 9px;
    display: grid; place-items: center;
  }

  .brand-icon svg { width: 20px; height: 20px; }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -.02em;
    color: var(--text);
  }

  .tagline {
    font-size: .8rem;
    color: var(--sub);
    margin-left: 46px;
    letter-spacing: .02em;
  }

  /* ─── PROGRESS BAR ───────────────────────────────────────── */
  .progress-wrap {
    margin-top: 20px;
    background: var(--elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 18px;
  }

  .progress-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
    font-size: .78rem;
    color: var(--text-dim);
  }

  .progress-pct {
    font-family: 'JetBrains Mono', monospace;
    font-size: .85rem;
    color: var(--accent-hi);
    font-weight: 500;
  }

  .progress-track {
    height: 6px;
    background: var(--border);
    border-radius: 99px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-hi));
    border-radius: 99px;
    width: 0%;
    transition: width .5s cubic-bezier(.4,0,.2,1);
  }

  /* ─── INPUT AREA ─────────────────────────────────────────── */
  .input-row {
    width: 100%;
    max-width: 580px;
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
  }

  .task-input {
    flex: 1;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 13px 16px;
    font-family: 'Inter', sans-serif;
    font-size: .92rem;
    color: var(--text);
    outline: none;
    transition: border-color var(--trans), box-shadow var(--trans);
  }

  .task-input::placeholder { color: var(--muted); }

  .task-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-lo);
  }

  .add-btn {
    background: var(--accent);
    border: none;
    border-radius: var(--radius);
    padding: 0 20px;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: .88rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background var(--trans), transform var(--trans), box-shadow var(--trans);
    display: flex; align-items: center; gap: 6px;
  }

  .add-btn:hover { background: var(--accent-hi); transform: translateY(-1px); box-shadow: 0 4px 16px #6366f155; }
  .add-btn:active { transform: translateY(0); }

  .add-btn svg { width: 16px; height: 16px; }

  /* ─── FILTER BAR ─────────────────────────────────────────── */
  .filter-bar {
    width: 100%;
    max-width: 580px;
    display: flex;
    gap: 6px;
    margin-bottom: 12px;
  }

  .filter-btn {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 7px 14px;
    font-size: .8rem;
    font-weight: 500;
    color: var(--sub);
    cursor: pointer;
    transition: all var(--trans);
    font-family: 'Inter', sans-serif;
  }

  .filter-btn:hover { color: var(--text); border-color: var(--accent); }

  .filter-btn.active {
    background: var(--accent-lo);
    border-color: var(--accent);
    color: var(--accent-hi);
  }

  .filter-count {
    display: inline-block;
    background: var(--elevated);
    border-radius: 99px;
    padding: 0 6px;
    font-size: .72rem;
    margin-left: 4px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-dim);
  }

  .filter-btn.active .filter-count {
    background: var(--accent);
    color: #fff;
  }

  /* ─── TASK LIST ───────────────────────────────────────────── */
  .task-list-wrap {
    width: 100%;
    max-width: 580px;
  }

  .task-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* ─── TASK ITEM ───────────────────────────────────────────── */
  .task-item {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 14px 14px 16px;
    transition: border-color var(--trans), transform var(--trans), box-shadow var(--trans), opacity var(--trans);
    animation: slideIn .22s cubic-bezier(.4,0,.2,1);
    position: relative;
    overflow: hidden;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .task-item.removing {
    animation: slideOut .22s cubic-bezier(.4,0,.2,1) forwards;
  }

  @keyframes slideOut {
    to { opacity: 0; transform: translateX(20px); height: 0; padding: 0; margin: 0; border-width: 0; }
  }

  .task-item:hover {
    border-color: #3a3f5a;
    transform: translateX(2px);
    box-shadow: var(--shadow);
  }

  .task-item.done { opacity: .55; }
  .task-item.done .task-text { text-decoration: line-through; color: var(--sub); }

  /* priority stripe */
  .task-item::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent);
    border-radius: 3px 0 0 3px;
    opacity: 0;
    transition: opacity var(--trans);
  }

  .task-item:hover::before { opacity: 1; }
  .task-item.done::before { background: var(--success); opacity: .5; }

  /* checkbox */
  .check-btn {
    width: 22px; height: 22px;
    min-width: 22px;
    border-radius: 50%;
    border: 2px solid var(--border);
    background: transparent;
    cursor: pointer;
    display: grid; place-items: center;
    transition: all var(--trans);
  }

  .check-btn:hover { border-color: var(--accent); background: var(--accent-lo); }

  .task-item.done .check-btn {
    border-color: var(--success);
    background: var(--success);
  }

  .check-btn svg { width: 12px; height: 12px; display: none; }
  .task-item.done .check-btn svg { display: block; }

  /* text */
  .task-text {
    flex: 1;
    font-size: .9rem;
    line-height: 1.5;
    color: var(--text);
    word-break: break-word;
    transition: color var(--trans);
    cursor: text;
    outline: none;
  }

  .task-text[contenteditable="true"] {
    cursor: text;
    background: var(--elevated);
    border-radius: 4px;
    padding: 2px 6px;
    box-shadow: 0 0 0 2px var(--accent);
  }

  /* timestamp */
  .task-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: .68rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* actions */
  .task-actions {
    display: flex;
    gap: 4px;
    opacity: 0;
    transition: opacity var(--trans);
  }

  .task-item:hover .task-actions { opacity: 1; }

  .icon-btn {
    width: 30px; height: 30px;
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--sub);
    cursor: pointer;
    display: grid; place-items: center;
    transition: all var(--trans);
  }

  .icon-btn:hover { background: var(--elevated); color: var(--text); }
  .icon-btn.del:hover { background: #f43f5e22; color: var(--danger); }
  .icon-btn svg { width: 14px; height: 14px; pointer-events: none; }

  /* ─── EMPTY STATE ─────────────────────────────────────────── */
  .empty-state {
    text-align: center;
    padding: 52px 24px;
    color: var(--muted);
    display: none;
  }

  .empty-state svg {
    width: 48px; height: 48px;
    margin: 0 auto 16px;
    opacity: .35;
  }

  .empty-state h3 {
    font-size: .95rem;
    font-weight: 500;
    margin-bottom: 6px;
    color: var(--text-dim);
  }

  .empty-state p { font-size: .82rem; }

  /* ─── FOOTER ACTIONS ─────────────────────────────────────── */
  .list-footer {
    width: 100%;
    max-width: 580px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 12px;
    padding: 0 2px;
    font-size: .78rem;
    color: var(--sub);
  }

  .clear-btn {
    background: transparent;
    border: none;
    color: var(--sub);
    font-size: .78rem;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    transition: all var(--trans);
  }

  .clear-btn:hover { color: var(--danger); background: #f43f5e15; }

  /* ─── TOAST ───────────────────────────────────────────────── */
  #toast {
    position: fixed;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 18px;
    font-size: .83rem;
    color: var(--text);
    box-shadow: var(--shadow);
    opacity: 0;
    transition: all .3s cubic-bezier(.4,0,.2,1);
    pointer-events: none;
    white-space: nowrap;
  }

  #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* ─── SCROLLBAR ───────────────────────────────────────────── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation-duration: .01ms !important; transition-duration: .01ms !important; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="brand">
    <div class="brand-icon">
      <svg fill="none" viewBox="0 0 20 20"><path d="M4 10l4 4 8-8" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <h1>TaskFlow</h1>
  </div>
  <p class="tagline">Stay focused. Ship things.</p>

  <div class="progress-wrap">
    <div class="progress-meta">
      <span id="progress-label">No tasks yet</span>
      <span class="progress-pct" id="progress-pct">—</span>
    </div>
    <div class="progress-track">
      <div class="progress-fill" id="progress-fill"></div>
    </div>
  </div>
</header>

<!-- INPUT -->
<div class="input-row">
  <input
    class="task-input"
    id="task-input"
    type="text"
    placeholder="Add a new task… (Enter to save)"
    maxlength="200"
    autocomplete="off"
  />
  <button class="add-btn" id="add-btn">
    <svg fill="none" viewBox="0 0 16 16"><path d="M8 2v12M2 8h12" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/></svg>
    Add
  </button>
</div>

<!-- FILTERS -->
<div class="filter-bar" id="filter-bar" role="tablist">
  <button class="filter-btn active" data-filter="all"       role="tab">All       <span class="filter-count" id="cnt-all">0</span></button>
  <button class="filter-btn"        data-filter="active"    role="tab">Active    <span class="filter-count" id="cnt-active">0</span></button>
  <button class="filter-btn"        data-filter="completed" role="tab">Completed <span class="filter-count" id="cnt-completed">0</span></button>
</div>

<!-- TASK LIST -->
<div class="task-list-wrap">
  <ul class="task-list" id="task-list" role="list"></ul>

  <div class="empty-state" id="empty-state">
    <svg fill="none" viewBox="0 0 48 48">
      <rect x="8" y="12" width="32" height="28" rx="4" stroke="currentColor" stroke-width="2"/>
      <path d="M16 20h16M16 28h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
    <h3 id="empty-title">No tasks yet</h3>
    <p id="empty-sub">Add something above to get started.</p>
  </div>
</div>

<!-- LIST FOOTER -->
<div class="list-footer" id="list-footer" style="display:none">
  <span id="footer-label"></span>
  <button class="clear-btn" id="clear-btn">Clear completed</button>
</div>

<!-- TOAST -->
<div id="toast"></div>

<script>
/* ──────────────────────────────────────────────
   STATE & STORAGE
────────────────────────────────────────────── */
const STORAGE_KEY = 'taskflow_tasks_v1';

let state = {
  tasks: [],        // [{ id, text, done, createdAt }]
  filter: 'all',    // 'all' | 'active' | 'completed'
};

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) state.tasks = JSON.parse(raw);
  } catch { state.tasks = []; }
}

function saveState() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(state.tasks));
}

function generateId() {
  return Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
}

/* ──────────────────────────────────────────────
   CRUD OPERATIONS
────────────────────────────────────────────── */
function createTask(text) {
  const task = { id: generateId(), text: text.trim(), done: false, createdAt: Date.now() };
  state.tasks.unshift(task);  // newest first
  saveState();
  return task;
}

function toggleTask(id) {
  const t = state.tasks.find(t => t.id === id);
  if (t) { t.done = !t.done; saveState(); }
}

function deleteTask(id) {
  state.tasks = state.tasks.filter(t => t.id !== id);
  saveState();
}

function updateTaskText(id, newText) {
  const t = state.tasks.find(t => t.id === id);
  if (t && newText.trim()) { t.text = newText.trim(); saveState(); }
}

function clearCompleted() {
  const n = state.tasks.filter(t => t.done).length;
  state.tasks = state.tasks.filter(t => !t.done);
  saveState();
  return n;
}

/* ──────────────────────────────────────────────
   DERIVED DATA
────────────────────────────────────────────── */
function getFiltered() {
  if (state.filter === 'active')    return state.tasks.filter(t => !t.done);
  if (state.filter === 'completed') return state.tasks.filter(t =>  t.done);
  return state.tasks;
}

function getCounts() {
  const all  = state.tasks.length;
  const done = state.tasks.filter(t => t.done).length;
  return { all, active: all - done, completed: done };
}

/* ──────────────────────────────────────────────
   RENDER
────────────────────────────────────────────── */
const taskListEl   = document.getElementById('task-list');
const emptyStateEl = document.getElementById('empty-state');
const emptyTitleEl = document.getElementById('empty-title');
const emptySubEl   = document.getElementById('empty-sub');
const listFooterEl = document.getElementById('list-footer');
const footerLabelEl= document.getElementById('footer-label');
const fillEl       = document.getElementById('progress-fill');
const pctEl        = document.getElementById('progress-pct');
const progressLblEl= document.getElementById('progress-label');
const cntAll       = document.getElementById('cnt-all');
const cntActive    = document.getElementById('cnt-active');
const cntCompleted = document.getElementById('cnt-completed');

function formatDate(ts) {
  const d = new Date(ts);
  return d.toLocaleDateString('en-IN', { day:'numeric', month:'short' });
}

function createTaskEl(task) {
  const li = document.createElement('li');
  li.className = 'task-item' + (task.done ? ' done' : '');
  li.dataset.id = task.id;
  li.setAttribute('role', 'listitem');

  li.innerHTML = `
    <button class="check-btn" data-action="toggle" aria-label="${task.done ? 'Mark incomplete' : 'Mark complete'}">
      <svg fill="none" viewBox="0 0 12 12"><path d="M2 6l3 3 5-5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <span class="task-text" contenteditable="false" data-action="text" spellcheck="true">${escHtml(task.text)}</span>
    <span class="task-date">${formatDate(task.createdAt)}</span>
    <div class="task-actions">
      <button class="icon-btn edit" data-action="edit" title="Edit task" aria-label="Edit task">
        <svg fill="none" viewBox="0 0 14 14"><path d="M9.5 1.5l3 3-8 8H1.5v-3l8-8z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
      </button>
      <button class="icon-btn del" data-action="delete" title="Delete task" aria-label="Delete task">
        <svg fill="none" viewBox="0 0 14 14"><path d="M2 3.5h10M5.5 3.5V2.5h3v1M5 5.5v5M9 5.5v5M3 3.5l.8 8h6.4l.8-8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>`;

  return li;
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function render() {
  const filtered = getFiltered();
  const counts   = getCounts();
  const total    = state.tasks.length;
  const done     = counts.completed;

  // progress
  if (total === 0) {
    fillEl.style.width = '0%';
    pctEl.textContent = '—';
    progressLblEl.textContent = 'No tasks yet';
  } else {
    const pct = Math.round((done / total) * 100);
    fillEl.style.width = pct + '%';
    pctEl.textContent = pct + '%';
    progressLblEl.textContent = `${done} of ${total} task${total !== 1 ? 's' : ''} done`;
  }

  // filter counts
  cntAll.textContent       = counts.all;
  cntActive.textContent    = counts.active;
  cntCompleted.textContent = counts.completed;

  // task list (smart diff: remove stale, add missing)
  const existingIds = new Set([...taskListEl.querySelectorAll('[data-id]')].map(el => el.dataset.id));
  const newIds = new Set(filtered.map(t => t.id));

  // remove tasks not in filtered
  existingIds.forEach(id => {
    if (!newIds.has(id)) {
      const el = taskListEl.querySelector(`[data-id="${id}"]`);
      if (el) { el.classList.add('removing'); setTimeout(() => el.remove(), 220); }
    }
  });

  // add / update
  filtered.forEach((task, i) => {
    let el = taskListEl.querySelector(`[data-id="${task.id}"]`);
    if (!el) {
      el = createTaskEl(task);
      // insert at correct position
      const refEl = taskListEl.children[i];
      taskListEl.insertBefore(el, refEl || null);
    } else {
      // sync done class
      el.classList.toggle('done', task.done);
      const textEl = el.querySelector('.task-text');
      if (textEl && textEl.contentEditable !== 'true') {
        if (textEl.textContent !== task.text) textEl.textContent = task.text;
      }
    }
  });

  // empty state
  const hasFiltered = filtered.length > 0;
  emptyStateEl.style.display = hasFiltered ? 'none' : 'block';
  if (!hasFiltered) {
    if (state.filter === 'active') {
      emptyTitleEl.textContent = 'All caught up!';
      emptySubEl.textContent = 'No active tasks. Time to kick back.';
    } else if (state.filter === 'completed') {
      emptyTitleEl.textContent = 'Nothing completed yet';
      emptySubEl.textContent = 'Finish some tasks to see them here.';
    } else {
      emptyTitleEl.textContent = 'No tasks yet';
      emptySubEl.textContent = 'Add something above to get started.';
    }
  }

  // footer
  listFooterEl.style.display = total > 0 ? 'flex' : 'none';
  footerLabelEl.textContent = `${counts.active} item${counts.active !== 1 ? 's' : ''} left`;
}

/* ──────────────────────────────────────────────
   EVENT HANDLING (delegated)
────────────────────────────────────────────── */
const inputEl  = document.getElementById('task-input');
const addBtnEl = document.getElementById('add-btn');
const filterBar= document.getElementById('filter-bar');
const clearBtn = document.getElementById('clear-btn');

function doAdd() {
  const text = inputEl.value.trim();
  if (!text) { shake(inputEl); return; }
  createTask(text);
  inputEl.value = '';
  render();
  showToast('Task added ✓');
}

addBtnEl.addEventListener('click', doAdd);

inputEl.addEventListener('keydown', e => {
  if (e.key === 'Enter') doAdd();
});

// delegated: task list
taskListEl.addEventListener('click', e => {
  const btn    = e.target.closest('[data-action]');
  if (!btn) return;
  const action = btn.dataset.action;
  const li     = btn.closest('[data-id]');
  if (!li) return;
  const id = li.dataset.id;

  if (action === 'toggle') {
    toggleTask(id);
    render();
  } else if (action === 'delete') {
    li.classList.add('removing');
    setTimeout(() => { deleteTask(id); render(); }, 200);
    showToast('Task deleted');
  } else if (action === 'edit') {
    startEdit(li, id);
  }
});

function startEdit(li, id) {
  const textEl = li.querySelector('.task-text');
  if (!textEl) return;
  textEl.contentEditable = 'true';
  textEl.focus();
  // move caret to end
  const range = document.createRange();
  range.selectNodeContents(textEl);
  range.collapse(false);
  const sel = window.getSelection();
  sel.removeAllRanges();
  sel.addRange(range);

  function commitEdit() {
    textEl.contentEditable = 'false';
    const newText = textEl.textContent.trim();
    if (newText) {
      updateTaskText(id, newText);
      showToast('Task updated');
    } else {
      // revert to original
      const task = state.tasks.find(t => t.id === id);
      if (task) textEl.textContent = task.text;
    }
    render();
  }

  textEl.addEventListener('blur', commitEdit, { once: true });
  textEl.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); textEl.blur(); }
    if (e.key === 'Escape') { textEl.textContent = state.tasks.find(t => t.id === id)?.text || ''; textEl.blur(); }
  }, { once: true });
}

// filter buttons
filterBar.addEventListener('click', e => {
  const btn = e.target.closest('[data-filter]');
  if (!btn) return;
  const filter = btn.dataset.filter;
  state.filter = filter;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.filter === filter));
  render();
});

// clear completed
clearBtn.addEventListener('click', () => {
  const n = clearCompleted();
  render();
  if (n > 0) showToast(`Cleared ${n} completed task${n !== 1 ? 's' : ''}`);
});

/* ──────────────────────────────────────────────
   UTILITIES
────────────────────────────────────────────── */
let toastTimer;
function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2200);
}

function shake(el) {
  el.style.animation = 'none';
  el.style.borderColor = 'var(--danger)';
  el.style.boxShadow  = '0 0 0 3px #f43f5e22';
  setTimeout(() => { el.style.borderColor = ''; el.style.boxShadow = ''; }, 600);
}

/* ──────────────────────────────────────────────
   INIT
────────────────────────────────────────────── */
loadState();
render();
</script>
</body>
</html>
